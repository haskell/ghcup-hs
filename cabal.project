import: cabal.project.common

optional-packages: ./vendored/*/*.cabal

if impl(ghc < 9.0)
    package ghcup
        flags: -tui -tar
else
    package ghcup
        flags: +tui +tar

package *
  test-show-details: direct

allow-newer: tar

source-repository-package
  type: git
  location: https://github.com/haskell/tar.git
  tag: c8de49e92b824af1184ab00e5f45bef64aded884
